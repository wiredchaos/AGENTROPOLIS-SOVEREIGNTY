{
  "name": "agentropolis-sovereignty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-check.mjs",
    "typecheck": "node scripts/build-check.mjs",
    "test": "node --test tests/**/*.test.js tests/sovereignty/*.test.js",
    "test:sovereignty": "node --test tests/sovereignty/*.test.js",
    "validate:registry": "node src/sovereignty/registry/validate.js",
    "gitleaks": "gitleaks detect --no-git --redact --source .",
    "ci": "npm ci --ignore-scripts && npm run typecheck && npm run test:sovereignty && npm run validate:registry && npm run build && npm test && npm run gitleaks"
  },
  "devDependencies": {}
}
